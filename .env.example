# Discord bot token from the Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# n8n production/test webhook URL that receives command payloads
N8N_WEBHOOK_URL=https://your-n8n-domain/webhook/ptr-ai-agent

# Root folder for customer, project, and design memory
# Windows example: C:\Users\YOUR_NAME\Desktop\PTR_AI_COMPANY\Memory
MEMORY_ROOT=./data/memory

# Optional settings
COMMAND_PREFIX=!
REQUEST_TIMEOUT_SECONDS=30
